# Acts 1:8 app — environment variables
#
# These power the "Ask Anything" chatbot. In production they go in
# Vercel: Project → Settings → Environment Variables (NOT committed to git).
# For local testing with `vercel dev`, copy this file to `.env.local`.

# Required for the chatbot to work. Get one at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-sonnet-4-6 (great balance of quality + cost).
# Set to claude-opus-4-8 for maximum quality (higher cost per message).
ANTHROPIC_MODEL=claude-sonnet-4-6
